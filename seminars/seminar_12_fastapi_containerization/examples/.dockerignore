# ============================================================
# .dockerignore — файлы, исключённые из контекста сборки
# ============================================================
# Docker копирует весь контекст сборки (директорию) на сервер
# перед выполнением Dockerfile. .dockerignore уменьшает размер
# контекста и ускоряет сборку.

# Виртуальное окружение Python — не нужно в образе
.venv/
venv/
env/

# Кеш Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Файлы с секретами — НИКОГДА не включать в образ!
.env
*.env
!.env.example

# Git
.git/
.gitignore

# Документация и тесты (не нужны в production-образе)
*.md
tests/
test_*.py

# IDE
.idea/
.vscode/
*.swp

# Локальная БД SQLite
*.db
*.sqlite3

# Логи
*.log
logs/

# OS
.DS_Store
Thumbs.db
