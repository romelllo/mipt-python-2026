# ============================================================
# Dockerfile для FastAPI-приложения Tasks API
# ============================================================
# Отличия от Django Dockerfile (семинар 08):
#   - Нет collectstatic (FastAPI не управляет статикой)
#   - Нет manage.py — используем alembic для миграций
#   - Запуск через uvicorn (ASGI), а не gunicorn (WSGI)
#   - Миграции запускаются в docker-compose command, не здесь
#
# Сборка: docker build -t tasks-api:latest .
# Запуск: docker run -p 8000:8000 tasks-api:latest

# ============================================================
# Базовый образ
# ============================================================
# python:3.11-slim — минимальный образ без лишних пакетов.
# Уменьшает размер образа (~150 МБ vs ~900 МБ для python:3.11).
FROM python:3.11-slim

# ============================================================
# Переменные окружения сборки
# ============================================================
# PYTHONDONTWRITEBYTECODE=1 — не создавать .pyc файлы
# PYTHONUNBUFFERED=1        — вывод stdout/stderr без буферизации
#                             (логи сразу видны в docker logs)
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# ============================================================
# Системные зависимости
# ============================================================
# libpq-dev — заголовки для psycopg2 (PostgreSQL драйвер)
# gcc       — компилятор для сборки C-расширений
# Удаляем кэш apt после установки — уменьшаем размер слоя.
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# ============================================================
# Рабочая директория
# ============================================================
WORKDIR /app

# ============================================================
# Зависимости Python
# ============================================================
# Копируем ТОЛЬКО requirements.txt перед кодом приложения.
# Это ключевой приём для кеширования слоёв Docker:
#   - Если requirements.txt не изменился → слой берётся из кеша
#   - pip install не запускается повторно при изменении кода
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

# ============================================================
# Код приложения
# ============================================================
# Копируем после установки зависимостей (кеш слоёв!)
COPY . .

# ============================================================
# Непривилегированный пользователь (безопасность)
# ============================================================
# Запуск от root — плохая практика: если контейнер взломают,
# атакующий получит root-доступ к хосту через escape.
# Создаём пользователя appuser без прав sudo.
RUN addgroup --system appgroup \
    && adduser --system --ingroup appgroup appuser \
    && chown -R appuser:appgroup /app

USER appuser

# ============================================================
# Порт
# ============================================================
# EXPOSE — документация: контейнер слушает порт 8000.
# Реальный проброс портов задаётся в docker-compose.yml (ports:)
# или при docker run -p 8000:8000.
EXPOSE 8000

# ============================================================
# Healthcheck
# ============================================================
# Docker проверяет /health каждые 30 секунд.
# Если 3 проверки подряд провалились — контейнер помечается unhealthy.
# depends_on с condition: service_healthy в compose ждёт этого статуса.
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD python -c \
    "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" \
    || exit 1

# ============================================================
# Команда запуска
# ============================================================
# uvicorn — ASGI-сервер для FastAPI (аналог gunicorn для Django).
# --host 0.0.0.0  — слушать на всех интерфейсах (не только localhost)
# --port 8000     — порт внутри контейнера
# --workers 2     — два рабочих процесса (для production)
#
# ВАЖНО: миграции (alembic upgrade head) НЕ запускаются здесь.
# Они запускаются в docker-compose.yml через command: sh -c "..."
# Это позволяет разделить ответственность и перезапускать
# только web-сервис без повторного применения миграций.
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]
