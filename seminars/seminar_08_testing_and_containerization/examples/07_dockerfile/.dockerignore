# ============================================================
# .dockerignore — файлы, которые НЕ копируются в Docker-образ
# ============================================================
# Аналог .gitignore, но для Docker.
# Уменьшает размер контекста сборки и предотвращает утечку секретов.

# ============================================================
# Python мусор
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ============================================================
# Виртуальное окружение
# ============================================================
.venv/
venv/
env/
ENV/

# ============================================================
# Тесты и покрытие
# ============================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
*.coveragerc

# ============================================================
# IDE и редакторы
# ============================================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================================
# Секреты и конфигурация окружения
# ============================================================
# НИКОГДА не включайте .env в Docker-образ!
.env
.env.*
*.env
secrets.txt
*.pem
*.key

# ============================================================
# База данных (SQLite)
# ============================================================
# БД должна быть в volume, не в образе
*.db
*.sqlite3
db.sqlite3

# ============================================================
# Логи
# ============================================================
*.log
logs/

# ============================================================
# Git
# ============================================================
.git/
.gitignore

# ============================================================
# Docker
# ============================================================
# Не нужно копировать сам Dockerfile и compose в образ
Dockerfile
docker-compose.yml
docker-compose.*.yml
.dockerignore

# ============================================================
# Документация (не нужна в production-образе)
# ============================================================
README.md
docs/
*.md
