# ============================================================
# Dockerfile для Django-приложения кафе
# ============================================================
# Базовый образ: python:3.11-slim — минимальный, без лишних пакетов
# Это уменьшает размер образа и снижает поверхность атаки.

FROM python:3.11-slim

# ============================================================
# Системные зависимости
# ============================================================
# --no-install-recommends — не устанавливать рекомендуемые пакеты
# Удаляем кэш apt после установки (уменьшаем размер слоя)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# ============================================================
# Рабочая директория
# ============================================================
WORKDIR /app

# ============================================================
# Зависимости Python
# ============================================================
# Копируем сначала только requirements.txt — это позволяет
# Docker кешировать этот слой и не переустанавливать зависимости
# при изменении только кода приложения.
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

# ============================================================
# Код приложения
# ============================================================
COPY . .

# ============================================================
# Создание непривилегированного пользователя
# ============================================================
# Запуск от root — небезопасно. Создаём пользователя appuser.
RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser

# Директория для SQLite базы данных (persistent volume будет примонтирован сюда)
RUN mkdir -p /app/data && chown -R appuser:appgroup /app/data

# Права на весь /app для appuser
RUN chown -R appuser:appgroup /app

# Переключаемся на непривилегированного пользователя
USER appuser

# ============================================================
# Статические файлы
# ============================================================
# collectstatic собирает все статические файлы в STATIC_ROOT
# DJANGO_SETTINGS_MODULE — указываем модуль настроек
RUN python manage.py collectstatic --noinput \
    --settings=cafe_project.settings \
    || echo "collectstatic skipped (no manage.py found at this path)"

# ============================================================
# Переменные окружения (по умолчанию)
# ============================================================
# Эти значения переопределяются через docker-compose.yml
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DJANGO_SETTINGS_MODULE=cafe_project.settings \
    PORT=8000

# ============================================================
# Порт
# ============================================================
EXPOSE 8000

# ============================================================
# Healthcheck — Docker проверяет, живо ли приложение
# ============================================================
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/menu/')" \
    || exit 1

# ============================================================
# Команда запуска — gunicorn (production WSGI-сервер)
# ============================================================
# Для разработки используйте: python manage.py runserver 0.0.0.0:8000
# Для продакшна — gunicorn:
#   --bind 0.0.0.0:8000  — слушаем на всех интерфейсах
#   --workers 2          — два рабочих процесса
#   --timeout 60         — таймаут запроса 60 секунд
CMD ["gunicorn", "cafe_project.wsgi:application", \
     "--bind", "0.0.0.0:8000", \
     "--workers", "2", \
     "--timeout", "60", \
     "--access-logfile", "-", \
     "--error-logfile", "-"]
