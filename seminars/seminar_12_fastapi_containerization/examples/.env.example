# ============================================================
# .env.example — пример файла переменных окружения
# ============================================================
# ИНСТРУКЦИЯ:
# 1. Скопируйте этот файл: cp .env.example .env
# 2. Замените значения на реальные
# 3. НИКОГДА не коммитьте .env в git (добавьте в .gitignore)!
#
# Этот файл (.env.example) — безопасно коммитить:
# он содержит только примеры значений, не реальные секреты.

# ============================================================
# PostgreSQL — настройки базы данных
# ============================================================
# Эти переменные читает официальный образ postgres:15-alpine
# при первом запуске для создания БД и пользователя.
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=changeme_use_strong_password_here
POSTGRES_DB=tasks_db

# ============================================================
# SQLAlchemy — строка подключения к БД
# ============================================================
# Формат: postgresql://user:password@host:port/dbname
#
# ВАЖНО: хост — это имя сервиса в docker-compose.yml ('db'),
# а не 'localhost'. Docker DNS разрешает 'db' в IP контейнера.
#
# Для локальной разработки без Docker замените 'db' на 'localhost':
# DATABASE_URL=postgresql://taskuser:changeme@localhost:5432/tasks_db
DATABASE_URL=postgresql://taskuser:changeme_use_strong_password_here@db:5432/tasks_db

# ============================================================
# FastAPI — настройки приложения
# ============================================================
# SECRET_KEY используется для подписи JWT-токенов (семинар 11).
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_random_64_char_hex_string_generated_by_secrets_module

# Режим отладки: 1 = включён (только для разработки!), 0 = выключен
DEBUG=0
